# Last Day - Environment Variables
# Copy this file to .env and fill in your actual keys
# NEVER commit .env to version control

# OpenAI (optional - for cloud-based dialogue fallback)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (optional - for cloud-based dialogue fallback)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Remove.bg (optional - for background removal API)
REMOVEBG_API_KEY=your_removebg_api_key_here

# Eleven Labs (optional - for voice generation)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# HuggingFace (optional - for model downloads)
HF_TOKEN=your_huggingface_token_here
