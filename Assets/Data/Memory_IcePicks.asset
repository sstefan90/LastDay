  memoryId: ice_picks
  objectName: Ice Picks
  objectSprite: {fileID: 21300000, guid: d931935c9ef3942ab9731a1812287caf, type: 3}
  glowSprite: {fileID: 21300000, guid: 3042cabc8c73a40a097d80c2d4b8e894, type: 3}
  shortDescription: A pair of old ice climbing picks, mounted on the wall. Scuffed
    and well-used.
  fullStory: "1989 \u2014 Robert and David climbed Mount Washington in February.
    Nearly died. Best weekend of their lives."
  marthaContext: "Martha was furious when they came home frostbitten. She made Robert
    promise never again. He kept that promise \u2014 she's not sure if that was the
    right thing to ask."
  davidContext: David still has his pair too. That climb was the day they stopped
    being friends and became brothers.
